#!/bin/bash
bar-network() {
	state=""
	if printf "%s" /sys/class/net/e* | grep -qv '\*'; then
		eth=$(cat /sys/class/net/e*/operstate)
	fi
	if printf "%s" /sys/class/net/w* | grep -qv '\*'; then
		wifi=$(cat /sys/class/net/w*/operstate)
	fi

	if printf "%s" /sys/class/net/tun* | grep -qv '\*'; then
		tun=$(cat /sys/class/net/tun*/operstate)
	fi
	
	internet_access_up=$(curl -sLI -o /dev/null -w "%{http_code}" --max-time 8 google.com)

	if [ "$internet_access_up" = "200" ]; then
		state=$state"󰖟"
	else
		state=$state""
	fi

	if [[ "$eth" == *"up"* ]]; then
		state=$state"󰈁"
	fi
	
	if [[ "$wifi" == *"up"* ]]; then
		state=$state"󰖩"
	fi
	
	if [[ "$tun" == *"up"* ]]; then
		state=$state""
	fi

	echo $state
}

bar-battery() {
	
	output=""
	if printf "%s" /sys/class/power_supply/BAT* | grep -qv '\*'; then
	
    	lap_battery_id=$(upower -e | grep 'BAT' | head -n 1)
    	lap_battery_info=$(upower -i "$lap_battery_id")
    	lap_battery_percentage=$(printf "%s\n" "$lap_battery_info" | awk '/percentage/ {print $2}')
		lap_battery_percentage=${lap_battery_percentage%\%}
		lap_battery_percentage=$(printf "%.0f" "${lap_battery_percentage}")
    	lap_battery_state=$(printf "%s\n" "$lap_battery_info" | awk '/state/ {print $2}')
		lap_battery_timeleft=""


		case "$lap_battery_state" in
			charging) 
				output=$output"󱐋"  
				lap_battery_timeleft=$(printf "%s\n" "$lap_battery_info" | awk '/time to full/ {print " " $4 substr($5,1,1)}')
				;; 
			fully-charged) output=$output"" ;;
		esac
		
		if [ "$lap_battery_state" = "discharging" ] || [ "$lap_battery_state" = "empty" ]; then
			
			lap_battery_timeleft=$(printf "%s\n" "$lap_battery_info" | awk '/time to empty/ {print " " $4 substr($5,1,1)}')
			
			if [ "$lap_battery_percentage" -gt 66 ]; then
				output=$output"󱊣"
			elif [ "$lap_battery_percentage" -gt 33 ]; then
				output=$output"󱊢"
			elif [ "$lap_battery_percentage" -gt 20 ]; then
				output=$output"󱊡"
			else
				dunstify -u critical " LOW BATTERY"
				output=$output"󰂎"
			fi
		fi
		
		output="$output${lap_battery_percentage}%${lap_battery_timeleft}"
	fi

	hsexists=$(upower -e | grep headset | head -n 1)
	if [ -n "$hsexists" ]; then
		headsetpower=$(upower -i "$hsexists" | awk '/percentage/ {print $2}')
		headsetpower=${headsetpower%\%}
		if [ "$headsetpower" -lt 20 ]; then
			dunstify -u critical '󰋎 LOW BATTERY'
			output="$output 󰋎${headsetpower}%"
		else
			output="$output 󰋎${headsetpower}%"
		fi
	fi
		
	echo -n "$output"

}

bar-cputemp() {
	payload=$(sensors -j 2>/dev/null)
	
	tempval=$(echo $payload | jq -e '.["coretemp-isa-0000"]["Package id 0"].temp1_input' 2>/dev/null)
	exitcode=$?
	if [ "$exitcode" == 0 ]; then
		output=$(printf "%.0f" "$tempval")
	fi
	
	tempval=$(echo $payload | jq -e '.["thinkpad-isa-0000"].CPU.temp1_input' 2>/dev/null)
	exitcode=$?
	if [ "$exitcode" == 0 ]; then
		output=$(printf "%.0f" "$tempval")
	fi

	tempval=$(echo $payload | jq -e '.["coretemp-isa-0000"]| to_entries | .[1].value| to_entries | map(select(.key | test("^temp[0-9]+_input$"))) | .[0].value' 2>/dev/null)
	exitcode=$?
	if [ "$exitcode" == 0 ]; then
		output=$(printf "%.0f" "$tempval")
	fi

	if [ -n "$output" ]; then
			echo ""$output"°C"
	fi
	
}

bar-memory() {
	echo $(free -h | awk '/^Mem/ { print $3"/"$2 }' | sed s/i//g)
}

bar-date() {
	echo $(date '+%Y-%m-%d %T %Z')
}

bar-wttr() {
	echo $(curl -s "wttr.in?format=2&location=Poissy")
}

bar-volume() {
	output=""

	source $(which asndenv)
	server_name=$(pactl info | grep "Server Name")

	if echo "$server_name" | grep -qi "pipewire"; then
		cspeaker_sink_input_id=$(
			pw-link -l | awk '
			/^from-desktop:/ {f=1; next}
			/^[^[:space:]]/  {f=0}
			f && /\|->/ {print $2}
			' | cut -d: -f1 | sort -u | grep -E '^(alsa_output|bluez_output)'
		)
		cspeaker_name=$cspeaker_sink_input_id

		mic_source_input_id=$(
			pw-link -l | awk '
			/^mic01-processed:/ {f=1; next}
			/^[^[:space:]]/     {f=0}
			f && /\|<-/ {print $2}
			' | cut -d: -f1 | sort -u | grep -E '^(alsa_input|bluez_input)'
		)
		mic_name=$mic_source_input_id

	else
		cspeaker_module_id=$(pactl list short modules | grep "sink_name=from-desktop" | awk '{print $1}')
		cspeaker_sink_input_id=$(pactl -f json list sink-inputs | jq -r ".[] | select(.owner_module == \"$cspeaker_module_id\") | .sink")
		cspeaker_name=$(pactl -f json list sinks | jq -r ".[] | select(.index == $cspeaker_sink_input_id ) | .name ")
		
		mic_module_id=$(pactl list short modules | grep "source_name=mic01-processed" | awk '{print $1}')
		mic_source_input_id=$(pactl -f json list source-outputs | jq -r ".[] | select(.owner_module == \"$mic_module_id\") | .source")
		mic_name=$(pactl -f json list sources | jq -r ".[] | select(.index == $mic_source_input_id ) | .name ")
	fi
	
	speakervol=$(pactl get-sink-volume $cspeaker_sink_input_id)
	micvol=$(pactl get-source-volume $mic_source_input_id)
	notconfigured=$?

	if [ $notconfigured -ne 0 ]; then
		output=$output"󰓄 N/A"
	else
		muted=$(pactl get-sink-mute $cspeaker_sink_input_id | awk '{print $2}')
		if [ "$muted" = "yes" ]; then
			output=$output"󰓄 Muted"
		else
			volume=$(echo $speakervol | head -n 1 | awk '{print $5}')
			output=$output"󰓃 $volume"
		fi
	fi

	desktopmuted=$(pactl get-sink-mute from-desktop | awk '{print $2}')
	if [ "$desktopmuted" = "yes" ]; then
		output=$output" 󰬅"
	else
		output=$output" 󰎇"
	fi

	callermuted=$(pactl get-sink-mute from-caller | awk '{print $2}')
	if [ "$callermuted" = "yes" ]; then
		output=$output" 󰬅"
	else
		output=$output" "
	fi

	if [ $notconfigured -eq 0 ]; then
		mic01muted=$(pactl get-source-mute mic01-processed | awk '{print $2}')
		if [ "$mic01muted" = "yes" ]; then
			output=$output" 󰬅"
		else
			output=$output" "
		fi
		
		mic02muted=$(pactl get-source-mute mic02-processed | awk '{print $2}')
		if [ "$mic02muted" = "yes" ]; then
			output=$output" 󰬅"
		else
			output=$output" "
		fi

		
		mvolume=$(echo $micvol | head -n 1 | awk '{print $5}')
		if [ "$mvolume" = "100%" ]; then
			output="$output 󰡴"
		else
			output="$output 󰡳"
		fi

		
	# 	tocallervol=$(pactl get-source-volume to-caller)
	# 	callervolume=$(echo $tocallervol | head -n 1 | awk '{print $5}')
	# 	output="$output $callervolume"
	fi

	# set mic name
	shortmicname=${shortsoundnames[${mic_name}]}
	if [ -z "$shortmicname" ]; then
		output="$output OTH"
	else
		output="$output $shortmicname"
	fi

	shortspeakername=${shortsoundnames[${cspeaker_name}]}
	if [ -z "$shortspeakername" ]; then
		output="$output/OTH"
	else
		output="$output/$shortspeakername"
	fi

	parecup=$(ps aux | grep -E  "parec.*desktop|parec.*mic01|parec.*mic02" | wc -l)
	if [ $parecup -gt 3 ]; then
		output="$output "
	fi

	echo $output
}

notifs(){
	if pgrep -x "dunst" > /dev/null; then
		notifispaused=$(dunstctl is-paused)
		if [ "$notifispaused" = "true" ]; then
			echo ""
		else
			echo ""
		fi
	fi
}

command=$1

if [ "$command" = "network" ]; then
	bar-network 
elif [ "$command" = "battery" ]; then
	bar-battery
elif [ "$command" = "cputemp" ]; then
	bar-cputemp
elif [ "$command" = "memory" ]; then
	bar-memory
elif [ "$command" = "date" ]; then
	bar-date
elif [ "$command" = "wttr" ]; then
	bar-wttr
elif [ "$command" = "volume" ]; then
	bar-volume
elif [ "$command" = "notifs" ]; then
	notifs
else
	echo "Invalid command"
fi
